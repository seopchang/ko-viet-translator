{
  "expo": {
    "name": "Simple Translator",
    "slug": "ko-viet-translator",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ko-viet-translator",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.koviet.translator"
    },
    "android": {
      "package": "com.koviet.translator",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "번역을 위해 사진 접근이 필요합니다.",
          "cameraPermission": "번역을 위해 카메라 접근이 필요합니다."
        }
      ],
      "expo-audio"
    ],
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Simple Translator",
      "shortName": "번역기",
      "description": "한국어-베트남어 번역기",
      "themeColor": "#3D2314",
      "backgroundColor": "#FAF8F5"
    }
  }
}
